# RAG写作系统配置示例
# 复制此文件为 .env 并填写实际值

# ========== LLM配置 ==========
# 提供商: openai / claude / siliconflow / zhipu / minimax
# DeepSeek使用openai兼容API，设置provider=openai，base_url指向DeepSeek
LLM__PROVIDER=openai
LLM__MODEL=deepseek-v4-pro
LLM__API_KEY=your-api-key-here
LLM__TEMPERATURE=0.7
LLM__MAX_TOKENS=4000
LLM__BASE_URL=https://api.deepseek.com

# ========== Milvus配置 ==========
MILVUS__HOST=localhost
MILVUS__PORT=19530
MILVUS__COLLECTION_NAME=wechat_articles
MILVUS__TOP_K=5

# ========== Embedding配置 ==========
EMBEDDING__MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING__DEVICE=cpu
EMBEDDING__BATCH_SIZE=32

# ========== 提示词配置 ==========
PROMPT__MAX_KNOWLEDGE_CHARS=8000
PROMPT__MIN_KNOWLEDGE_CHARS=2000
