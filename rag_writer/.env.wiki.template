# 行业稿件写作 .env 模板 — Wiki 混合模式
# 复制为 .env 后填实际值, 或在系统环境变量设

# === Wiki API Server (本机 IP) ===
# 本机运行 `python e:/deepsearch/wiki_api_server.py --port 8088 --host 0.0.0.0 --api-key deepsearch123`
# 服务器通过局域网 HTTP 调用本机
WIKI_API_URL=http://192.168.x.x:8088
WIKI_API_KEY=deepsearch123

# === 知识库模式 (产品上下文检索) ===
# "rag":    纯 Milvus 产品库 (原行为, 不调本机)
# "wiki":   纯 LLM-Wiki (强制走本机, 失败返回空)
# "hybrid": Wiki 优先, 失败/无结果降级 RAG (推荐)
WIKI__KNOWLEDGE_MODE=hybrid
WIKI__TIMEOUT_SEC=60

# === Milvus (行业稿件库 - 保留) ===
MILVUS__HOST=localhost
MILVUS__PORT=19530
MILVUS__COLLECTION_NAME=rag_articles
MILVUS__TOP_K=5

# === LLM (写稿用) ===
LLM__PROVIDER=openai
LLM__MODEL=deepseek-v4-pro
LLM__API_KEY=sk-xxx
LLM__BASE_URL=https://api.deepseek.com
